{
  "name": "bauhaus-ui-library",
  "version": "0.1.0",
  "description": "A bold, geometric React component library inspired by the Bauhaus movement.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "ui",
    "component-library",
    "bauhaus",
    "tailwind",
    "design-system",
    "dark-mode"
  ],
  "author": "Xhulio Lavdari",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xhu96/bauhaus-ui-library.git"
  },
  "homepage": "https://xhu96.github.io/bauhaus-ui-library/",
  "bugs": {
    "url": "https://github.com/xhu96/bauhaus-ui-library/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/bauhaus-ui.umd.cjs",
  "module": "./dist/bauhaus-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bauhaus-ui.js",
      "require": "./dist/bauhaus-ui.umd.cjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "tsc --noEmit && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build:lib"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.408.0",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@microsoft/api-extractor": "^7.58.9",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.6.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.39",
    "prettier": "^3.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^2.1.9"
  }
}
